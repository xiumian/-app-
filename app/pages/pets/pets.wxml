<view class="container">
  <view class="card hero">
    <view class="eyebrow">????</view>
    <view class="title">{{pets.length}} ???</view>
    <view class="muted">????????????????????</view>
  </view>

  <view class="card">
    <view class="section-title">????</view>
    <view class="form">
      <input class="input" placeholder="?????????" value="{{form.name}}" data-field="name" bindinput="onInput" />
      <input class="input" placeholder="??????? / ?" value="{{form.species}}" data-field="species" bindinput="onInput" />
      <input class="input" placeholder="?????????" value="{{form.breed}}" data-field="breed" bindinput="onInput" />
      <input class="input" placeholder="?? emoji??????" value="{{form.avatar}}" data-field="avatar" bindinput="onInput" />
      <button class="btn" bindtap="addPet">????</button>
    </view>
  </view>

  <view class="card">
    <view class="section-title">????</view>
    <view class="list">
      <view wx:for="{{pets}}" wx:key="id" class="item" bindtap="selectPet" data-id="{{item.id}}">
        <view class="row">
          <view class="row" style="justify-content:flex-start;">
            <view class="avatar">{{item.avatar}}</view>
            <view>
              <view class="item-title">{{item.name}}</view>
              <view class="item-sub">{{item.species}} ? {{item.breed || '????'}} ? {{item.weight || '???'}}kg</view>
            </view>
          </view>
          <view class="pill">{{item.id === selectedPetId ? '???' : '????'}}</view>
        </view>
        <view wx:if="{{item.note}}" class="item-sub">{{item.note}}</view>
      </view>
    </view>
  </view>
</view>
