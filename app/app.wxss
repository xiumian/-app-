page {
  min-height: 100vh;
  background: radial-gradient(circle at 12% 4%, #fff5dc 0 15%, transparent 31%), #f3eadf;
  color: #49372a;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}
.container { padding: 28rpx 28rpx 120rpx; box-sizing: border-box; }
.card { margin-bottom: 24rpx; padding: 28rpx; border-radius: 36rpx; background: rgba(255,250,242,.96); box-shadow: 0 18rpx 46rpx rgba(92,64,42,.12); border: 1rpx solid rgba(255,255,255,.85); }
.hero { background: linear-gradient(135deg,#fff7eb,#ead5bd); }
.row { display: flex; align-items: center; justify-content: space-between; gap: 18rpx; }
.stack { display: flex; flex-direction: column; gap: 16rpx; }
.eyebrow { color: #9a7c66; font-size: 22rpx; font-weight: 800; letter-spacing: .08em; }
.title { margin-top: 8rpx; font-size: 48rpx; line-height: 1.05; font-weight: 900; letter-spacing: -1rpx; color: #3d2b20; }
.h2 { font-size: 34rpx; font-weight: 900; color: #3d2b20; }
.muted { color: #927e6e; font-size: 25rpx; line-height: 1.65; }
.avatar { width: 96rpx; height: 96rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(145deg,#f2e7d9,#fffaf2); font-size: 48rpx; flex: 0 0 auto; }
.pill { display: inline-flex; align-items: center; min-height: 48rpx; padding: 0 20rpx; border-radius: 999rpx; background: #f3eadf; color: #6f4b34; font-size: 24rpx; font-weight: 800; }
.grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18rpx; }
.stat { padding: 24rpx; border-radius: 28rpx; background: rgba(255,255,255,.72); border: 1rpx solid #eadfd3; }
.stat .num { display:block; font-size: 42rpx; font-weight: 900; color:#3d2b20; }
.stat .label { display:block; margin-top: 4rpx; color:#9a8778; font-size: 23rpx; font-weight:800; }
.btn { min-height: 84rpx; border-radius: 999rpx; border: 0; background: #8f6545; color: #fff; font-size: 28rpx; font-weight: 900; }
.btn.ghost { background: #fffaf2; color: #6f4b34; border: 1rpx solid #ded1c3; }
.btn.danger { background: #ce675e; color:#fff; }
.input, .textarea, .picker { width: 100%; min-height: 84rpx; padding: 0 24rpx; box-sizing: border-box; border: 1rpx solid #ded1c3; border-radius: 24rpx; background: rgba(255,255,255,.9); color: #49372a; font-size: 28rpx; }
.textarea { min-height: 150rpx; padding-top: 22rpx; }
.list { display:flex; flex-direction:column; gap:18rpx; }
.item { padding: 22rpx; border-radius: 28rpx; background: rgba(255,255,255,.72); border: 1rpx solid #eadfd3; }
.item-title { font-size: 30rpx; font-weight: 900; color:#3d2b20; }
.item-sub { margin-top: 6rpx; color:#927e6e; font-size: 24rpx; line-height: 1.55; }
.empty { padding: 36rpx 24rpx; border: 1rpx dashed #d8c8b8; border-radius: 28rpx; color:#927e6e; text-align:center; background: rgba(255,250,242,.62); }
.check-row { display:flex; align-items:center; justify-content:space-between; gap:16rpx; }
.checkbox-dot { width: 42rpx; height: 42rpx; border-radius: 50%; border: 4rpx solid #e1d4c6; display:flex; align-items:center; justify-content:center; color:#fff; font-size:24rpx; }
.checkbox-dot.done { background:#48cf7b; border-color:#48cf7b; }
.form { display:flex; flex-direction:column; gap:18rpx; }
.section-title { margin: 10rpx 0 18rpx; font-size: 34rpx; font-weight: 900; color:#3d2b20; }
