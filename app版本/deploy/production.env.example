# Copy this file to deploy/production.env and replace every placeholder before deployment.
# Do not commit deploy/production.env.

APP_VERSION=0.4.0

PET_CORS_ORIGIN=https://app.example.com
PET_AUTH_RATE_LIMIT_MAX=30
PET_AUTH_RATE_LIMIT_WINDOW_MS=300000
PET_TRUST_PROXY=true
PET_MONITORING_RATE_LIMIT_MAX=120
PET_MONITORING_RATE_LIMIT_WINDOW_MS=60000
PET_BACKUP_RETENTION_MAX=20
PET_SERVER_REQUEST_TIMEOUT_MS=30000
PET_SERVER_HEADERS_TIMEOUT_MS=15000
PET_SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
PET_ACCESS_TOKEN_TTL_MS=604800000
PET_REFRESH_TOKEN_TTL_MS=2592000000
PET_AUTH_SECRET=replace-with-random-auth-secret-at-least-32-chars
PET_MAX_BODY_BYTES=2097152
PET_SERVER_LOG_LEVEL=info

PET_MEDIA_STORAGE_DRIVER=local
PET_MEDIA_LOCAL_DIR=/data/media
# Optional: set only if media should use an external public base URL.
PET_MEDIA_PUBLIC_BASE_URL=
# Optional future upgrade: switch PET_MEDIA_STORAGE_DRIVER=s3 and fill these.
PET_MEDIA_S3_ENDPOINT=
PET_MEDIA_S3_REGION=
PET_MEDIA_S3_BUCKET=
PET_MEDIA_S3_PREFIX=pet-media
PET_MEDIA_S3_ACCESS_KEY_ID=
PET_MEDIA_S3_SECRET_ACCESS_KEY=
PET_MEDIA_MAX_BYTES=1572864
